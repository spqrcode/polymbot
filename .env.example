# Polymarket Bot - Configuration

# Polygon wallet (required for LIVE)
PRIVATE_KEY=

# API credentials (optional - derived automatically if empty)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Dry-run mode (true = no real orders)
DRY_RUN=true
PAPER_TRADING=true
SESSION_DURATION_HOURS=120
REPORT_DIR=reports
MAX_CONSECUTIVE_API_ERRORS=5

# Live / tiny-live parameters
MAX_CAPITAL=50
MAX_PER_MARKET=3
ORDER_SIZE=0.50
MAX_MARKETS=12
MAX_OPEN_ORDERS=25
DRAWDOWN_LIMIT=-5
MIN_SPREAD_CENTS=4
MAX_SUM_CENTS=103
PRICE_RANGE_MIN=0.20
PRICE_RANGE_MAX=0.80
COMPETITION=low
SCAN_INTERVAL_SEC=8
HOLD_INTERVAL_SEC=60
REPRICE_INTERVAL_SEC=8
REPRICE_THRESHOLD_CENTS=0.5
MAX_BOOK_AGE_SEC=60
UNHEDGED_ALERT_CYCLES=3
TARGET_ENTRY_ORDERS=0
TARGET_ENTRY_FILL_EVENTS=0
PROFIT_TARGET=0

# Live guardrails
MIN_USDC_BUFFER=2
ALLOW_EXISTING_OPEN_ORDERS=false
ALLOW_EXISTING_POSITIONS=false
ALLOW_FEE_ENABLED_MARKETS=false
MAX_ALLOWED_FEE_RATE_BPS=10000
USE_WEBSOCKET=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
