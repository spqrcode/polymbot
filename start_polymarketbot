#!/bin/zsh
set -euo pipefail
unsetopt BG_NICE 2>/dev/null || true

ROOT_DIR="${0:A:h}"
RUNTIME_DIR="$ROOT_DIR/runtime"
RUNTIME_ENV="$RUNTIME_DIR/session.env"
LEGACY_RUNTIME_ENV="$RUNTIME_DIR/launchd.env"
MANAGER_PID_FILE="$RUNTIME_DIR/manager.pid"
CHILD_PID_FILE="$RUNTIME_DIR/polymarketbot.pid"
MANAGER_LOG="$RUNTIME_DIR/manager.log"

mkdir -p "$RUNTIME_DIR" "$ROOT_DIR/reports"

is_pid_running() {
    local pid="$1"
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null
}

if [[ -f "$MANAGER_PID_FILE" ]]; then
    existing_manager_pid="$(<"$MANAGER_PID_FILE")"
    if is_pid_running "$existing_manager_pid"; then
        echo "The bot is already running with manager PID $existing_manager_pid."
        echo "Use ./status_polymarketbot or ./stop_polymarketbot."
        exit 1
    fi
    rm -f "$MANAGER_PID_FILE" "$CHILD_PID_FILE"
fi

if [[ ! -f "$ROOT_DIR/.env" ]]; then
    echo "Note: .env not found. Copy .env.example to .env before using live trading."
fi

prompt_mode() {
    local value
    while true; do
        printf "Mode [paper/live] [paper]: " >&2
        read -r value
        value="${${value:-paper}:l}"
        if [[ "$value" == "paper" || "$value" == "live" ]]; then
            print -r -- "$value"
            return
        fi
        echo "Enter 'paper' or 'live'." >&2
    done
}

prompt_nonnegative_int() {
    local prompt="$1"
    local default_value="$2"
    local value
    while true; do
        printf "%s [%s]: " "$prompt" "$default_value" >&2
        read -r value
        value="${value:-$default_value}"
        if [[ "$value" =~ '^[0-9]+$' ]]; then
            print -r -- "$value"
            return
        fi
        echo "Enter an integer >= 0." >&2
    done
}

prompt_nonnegative_float() {
    local prompt="$1"
    local default_value="$2"
    local value
    while true; do
        printf "%s [%s]: " "$prompt" "$default_value" >&2
        read -r value
        value="${value:-$default_value}"
        if [[ "$value" =~ '^[0-9]+([.][0-9]+)?$' ]]; then
            print -r -- "$value"
            return
        fi
        echo "Enter a number >= 0." >&2
    done
}

prompt_positive_float() {
    local prompt="$1"
    local default_value="$2"
    local value
    while true; do
        value="$(prompt_nonnegative_float "$prompt" "$default_value")"
        if [[ "$value" != "0" && "$value" != "0.0" ]]; then
            print -r -- "$value"
            return
        fi
        echo "Enter a number > 0." >&2
    done
}

mode="$(prompt_mode)"
target_entry_orders="$(prompt_nonnegative_int "Max entry orders (0 = no limit)" "0")"
profit_target="$(prompt_nonnegative_float "Profit target USD (0 = no limit)" "0")"
loss_stop="$(prompt_positive_float "Stop loss USD" "5")"
duration_minutes="$(prompt_nonnegative_float "Max duration minutes (0 = unlimited)" "0")"

if [[ "$mode" == "live" ]]; then
    confirm_value=""
    printf "Confirm LIVE trading with real funds by typing LIVE: " >&2
    read -r confirm_value
    if [[ "$confirm_value" != "LIVE" ]]; then
        echo "Startup cancelled."
        exit 1
    fi
fi

duration_hours="0"
if [[ "$duration_minutes" != "0" && "$duration_minutes" != "0.0" ]]; then
    duration_hours="$(LC_NUMERIC=C awk "BEGIN { printf \"%.6f\", $duration_minutes / 60 }")"
fi

dry_run="true"
paper_trading="true"
if [[ "$mode" == "live" ]]; then
    dry_run="false"
    paper_trading="false"
fi

umask 077
cat > "$RUNTIME_ENV" <<EOF
# Generated by start_polymarketbot on $(date -u +"%Y-%m-%dT%H:%M:%SZ")
DRY_RUN=$dry_run
PAPER_TRADING=$paper_trading
USE_WEBSOCKET=true
SESSION_DURATION_HOURS=$duration_hours
SESSION_DURATION_MINUTES=$duration_minutes
TARGET_ENTRY_ORDERS=$target_entry_orders
TARGET_ENTRY_FILL_EVENTS=0
PROFIT_TARGET=$profit_target
DRAWDOWN_LIMIT=-$loss_stop
REPORT_DIR=reports
EOF

if [[ -f "$LEGACY_RUNTIME_ENV" && "$LEGACY_RUNTIME_ENV" != "$RUNTIME_ENV" ]]; then
    cp "$RUNTIME_ENV" "$LEGACY_RUNTIME_ENV"
fi

nohup "$ROOT_DIR/scripts/run_background.sh" > "$MANAGER_LOG" 2>&1 < /dev/null &
manager_pid=$!
echo "$manager_pid" > "$MANAGER_PID_FILE"
sleep 1

if ! is_pid_running "$manager_pid"; then
    rm -f "$MANAGER_PID_FILE" "$CHILD_PID_FILE"
    echo "The bot exited immediately after startup. Check:"
    echo "  $MANAGER_LOG"
    echo "  $RUNTIME_DIR/polymarketbot.log"
    exit 1
fi

echo "Run configuration saved to $RUNTIME_ENV"
echo "Mode: $mode | max entry orders: $target_entry_orders | profit target: \$$profit_target | stop loss: -\$$loss_stop | duration minutes: $duration_minutes"
echo "Manager PID: $manager_pid"
if [[ -f "$CHILD_PID_FILE" ]]; then
    echo "Bot PID: $(<"$CHILD_PID_FILE")"
fi
echo "Runtime log: $RUNTIME_DIR/polymarketbot.log"
