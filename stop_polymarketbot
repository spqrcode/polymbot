#!/bin/zsh
set -euo pipefail

ROOT_DIR="${0:A:h}"
MANAGER_PID_FILE="$ROOT_DIR/runtime/manager.pid"
CHILD_PID_FILE="$ROOT_DIR/runtime/polymarketbot.pid"

is_pid_running() {
    local pid="$1"
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null
}

stop_pid() {
    local pid="$1"
    kill -INT "$pid" 2>/dev/null || true
}

wait_for_pid_exit() {
    local pid="$1"
    local attempts="${2:-40}"

    while (( attempts > 0 )); do
        if ! is_pid_running "$pid"; then
            return 0
        fi
        sleep 0.25
        (( attempts -= 1 ))
    done

    return 1
}

cleanup_stale_files() {
    local manager_alive=0
    local child_alive=0

    if [[ -f "$MANAGER_PID_FILE" ]] && is_pid_running "$(<"$MANAGER_PID_FILE")"; then
        manager_alive=1
    fi
    if [[ -f "$CHILD_PID_FILE" ]] && is_pid_running "$(<"$CHILD_PID_FILE")"; then
        child_alive=1
    fi

    if [[ "$manager_alive" -eq 0 ]]; then
        rm -f "$MANAGER_PID_FILE"
    fi
    if [[ "$child_alive" -eq 0 ]]; then
        rm -f "$CHILD_PID_FILE"
    fi
}

if [[ -f "$MANAGER_PID_FILE" ]]; then
    manager_pid="$(<"$MANAGER_PID_FILE")"
    if is_pid_running "$manager_pid"; then
        stop_pid "$manager_pid"
        wait_for_pid_exit "$manager_pid" || {
            echo "shutdown in progress for manager PID $manager_pid"
            exit 1
        }
        cleanup_stale_files
        echo "stopped manager PID $manager_pid"
        exit 0
    fi
fi

if [[ -f "$CHILD_PID_FILE" ]]; then
    child_pid="$(<"$CHILD_PID_FILE")"
    if is_pid_running "$child_pid"; then
        stop_pid "$child_pid"
        wait_for_pid_exit "$child_pid" || {
            echo "shutdown in progress for bot PID $child_pid"
            exit 1
        }
        cleanup_stale_files
        echo "stopped bot PID $child_pid"
        exit 0
    fi
fi

cleanup_stale_files
echo "bot not active"
